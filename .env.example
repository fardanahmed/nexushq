# Separate backend service
PUBLIC_BACKEND_API_URL=http://localhost:8787

# Server-side rendering can use a private URL if it differs from the browser URL.
# BACKEND_API_URL=http://localhost:8787

# Cloudflare R2 Storage (Optional)
# If provided, images will serve from R2. If missing, falls back to /assets
PUBLIC_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
