!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# astro & vercel
.astro/
dist/
.vercel/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files (never commit these!)
.env
.env*.local
.env.development
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea

# IDE - WebStorm/IntelliJ
.idea/
*.iws
*.iml
*.ipr

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Logs
logs
*.log

# Cache directories
.cache
.parcel-cache
.turbo

# Development artifacts
.agent/
.agents/
*.local.md
docs/

# Local development scripts
cmd_init.bat
powershell_init.ps1
consultancy_context.md

