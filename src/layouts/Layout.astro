---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/shared/Navbar';
import Footer from '../components/shared/Footer';
import Interactive3DBackground from '../components/home/Interactive3DBackground';
import '../styles/globals.css';
import { getSiteSettings } from '../lib/content-api';
import type { SiteData } from '../types';

interface Props {
  title?: string;
  description?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, schema } = Astro.props;

// Fetch site-wide data for SEO, metadata, and footer
const siteData = await getSiteSettings<SiteData>('site_data');
const defaultTitle = siteData 
  ? `${siteData.abbreviation} | ${siteData.name}`
  : 'NexusHQ | The Coaching Platform for Modern Mentors';

const defaultDesc = siteData?.tagline || 'The all-in-one platform for coaches, tutors, and mentors to manage clients, bookings, and sessions.';
const displayTitle = title ? `${title} | NexusHQ` : defaultTitle;
const displayDesc = description || defaultDesc;
---

<!doctype html>
<html lang="en" class="dark" style="scrollbar-gutter: stable;" suppressHydrationWarning>
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#4f46e5" />
    
    <title>{displayTitle}</title>
    <meta name="description" content={displayDesc} />
    
    <!-- OpenGraph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={displayTitle} />
    <meta property="og:description" content={displayDesc} />
    <meta property="og:image" content="/og-image.png" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={displayTitle} />
    <meta property="twitter:description" content={displayDesc} />
    <meta property="twitter:image" content="/og-image.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Enforce dark mode to match 3D concept aesthetics -->
    <script is:inline>
      document.documentElement.classList.add('dark');
      if (typeof localStorage !== 'undefined') {
        localStorage.setItem('theme', 'dark');
      }

      // Unified loader manager
      const hideLoader = () => {
        const loader = document.getElementById('global-loader');
        if (loader) {
          loader.style.opacity = '0';
          setTimeout(() => {
            loader.remove();
            document.body.style.overflow = '';
          }, 700);
        } else {
          document.body.style.overflow = '';
        }
      };

      // Listen for the React 3D scene ready signal
      window.addEventListener('3d-scene-ready', () => {
        window.is3dSceneLoaded = true;
        hideLoader();
      });

      // Handle after-swap during Astro ClientRouter navigations
      document.addEventListener('astro:after-swap', () => {
        if (window.is3dSceneLoaded === true) {
          const loader = document.getElementById('global-loader');
          if (loader) {
            loader.style.display = 'none';
            loader.remove();
          }
          document.body.style.overflow = '';
        }
      });

      // Handle page-load (covers initial load and after-transition completes)
      document.addEventListener('astro:page-load', () => {
        if (window.is3dSceneLoaded === true) {
          // If already loaded, immediately remove the loader
          const loader = document.getElementById('global-loader');
          if (loader) {
            loader.style.display = 'none';
            loader.remove();
          }
          document.body.style.overflow = '';
        } else {
          // If this is the initial site load, lock scroll
          document.body.style.overflow = 'hidden';
          
          // Failsafe timer (4 seconds)
          setTimeout(() => {
            if (!window.is3dSceneLoaded) {
              window.dispatchEvent(new Event('3d-scene-ready'));
            }
          }, 4000);
        }
      });
    </script>
    {schema && <script type="application/ld+json" is:inline set:html={JSON.stringify(schema).replace(/</g, '\\u003c').replace(/>/g, '\\u003e')} />}
  </head>
  <body class="bg-background text-foreground font-sans antialiased selection:bg-primary/20 selection:text-primary">
    <Interactive3DBackground client:load transition:persist />
    <div class="flex min-h-screen flex-col">
      <!-- client:load is needed for mobile collapsible navigation and theme-switching interactions -->
      <header>
        <Navbar client:load />
      </header>
      <main class="flex-1">
        <slot />
      </main>
      <!-- Footer handles dynamic data passed from server frontmatter -->
      <Footer siteData={siteData} />
    </div>

    <!-- Global Loading Screen overlay -->
    <div id="global-loader" class="fixed inset-0 z-[100] flex flex-col items-center justify-center bg-[#0f0a1e] transition-opacity duration-700">
      <!-- 3D Gyroscope Loader -->
      <div class="gyroscope mb-12">
        <div class="gyro-ring"></div>
        <div class="gyro-ring"></div>
        <div class="gyro-ring"></div>
        <div class="gyro-core"></div>
      </div>
      
      <!-- Text -->
      <h2 class="text-3xl font-bold tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-amber-400 animate-pulse">NexusHQ</h2>
      <p class="text-slate-400 mt-2 tracking-widest text-sm uppercase">Initializing</p>
    </div>
    
    <style>
      .gyroscope {
        width: 140px;
        height: 140px;
        position: relative;
        perspective: 1000px;
        transform-style: preserve-3d;
      }
      .gyro-ring {
        position: absolute;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        border: 3px solid transparent;
        box-shadow: inset 0 0 15px rgba(255,255,255,0.05);
      }
      .gyro-ring:nth-child(1) {
        border-top-color: #6366f1; /* Indigo */
        border-bottom-color: #6366f1;
        animation: spin1 2s linear infinite;
      }
      .gyro-ring:nth-child(2) {
        border-right-color: #f59e0b; /* Amber */
        border-left-color: #f59e0b;
        animation: spin2 2.5s linear infinite;
      }
      .gyro-ring:nth-child(3) {
        border-top-color: #818cf8; /* Indigo-400 */
        border-bottom-color: #818cf8;
        animation: spin3 3s linear infinite;
      }
      .gyro-core {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 30px;
        height: 30px;
        margin: -15px 0 0 -15px;
        background: radial-gradient(circle, #6366f1, #f59e0b);
        border-radius: 50%;
        box-shadow: 0 0 30px #6366f1, 0 0 60px #f59e0b;
        animation: pulse-core 2s infinite alternate;
      }

      @keyframes spin1 { 
        0% { transform: rotateX(60deg) rotateY(0deg) rotateZ(0deg); } 
        100% { transform: rotateX(60deg) rotateY(0deg) rotateZ(360deg); } 
      }
      @keyframes spin2 { 
        0% { transform: rotateX(0deg) rotateY(60deg) rotateZ(0deg); } 
        100% { transform: rotateX(0deg) rotateY(60deg) rotateZ(360deg); } 
      }
      @keyframes spin3 { 
        0% { transform: rotateX(45deg) rotateY(45deg) rotateZ(0deg); } 
        100% { transform: rotateX(45deg) rotateY(45deg) rotateZ(360deg); } 
      }
      @keyframes pulse-core { 
        0% { transform: scale(0.8); opacity: 0.8; } 
        100% { transform: scale(1.2); opacity: 1; } 
      }
    </style>

    <!-- Unified loader manager in head handles this script block -->
  </body>
</html>
