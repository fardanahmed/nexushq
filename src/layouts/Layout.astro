---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/shared/Navbar';
import Footer from '../components/shared/Footer';
import '../styles/globals.css';
import { getSiteSettings } from '../lib/content-api';
import type { SiteData } from '../types';

interface Props {
  title?: string;
  description?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, schema } = Astro.props;

// Fetch site-wide data for SEO, metadata, and footer
const siteData = await getSiteSettings<SiteData>('site_data');
const defaultTitle = siteData 
  ? `${siteData.abbreviation} | ${siteData.name}`
  : 'CARER | Nasir Uddin Centre for Applied Research & Educational Resources';

const defaultDesc = siteData?.tagline || 'Bridging academia and industry through cutting-edge research in energy, health, agriculture, and digital systems.';
const displayTitle = title ? `${title} | CARER` : defaultTitle;
const displayDesc = description || defaultDesc;
---

<!doctype html>
<html lang="en" class="dark" suppressHydrationWarning>
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1e40af" />
    
    <title>{displayTitle}</title>
    <meta name="description" content={displayDesc} />
    
    <!-- OpenGraph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={displayTitle} />
    <meta property="og:description" content={displayDesc} />
    <meta property="og:image" content="/og-image.png" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={displayTitle} />
    <meta property="twitter:description" content={displayDesc} />
    <meta property="twitter:image" content="/og-image.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Enforce dark mode to match 3D concept aesthetics -->
    <script is:inline>
      document.documentElement.classList.add('dark');
      if (typeof localStorage !== 'undefined') {
        localStorage.setItem('theme', 'dark');
      }
    </script>
    {schema && <script type="application/ld+json" is:inline set:html={JSON.stringify(schema).replace(/</g, '\\u003c').replace(/>/g, '\\u003e')} />}
  </head>
  <body class="bg-background text-foreground font-sans antialiased selection:bg-primary/20 selection:text-primary">
    <div class="flex min-h-screen flex-col">
      <!-- client:load is needed for mobile collapsible navigation and theme-switching interactions -->
      <header>
        <Navbar client:load />
      </header>
      <main class="flex-1">
        <slot />
      </main>
      <!-- Footer handles dynamic data passed from server frontmatter -->
      <Footer siteData={siteData} />
    </div>
  </body>
</html>
