---
import Layout from '../layouts/Layout.astro';
import ResearchGrid from '../components/home/ResearchGrid';
import Integrations from '../components/home/Integrations';
import { getFeatures } from '../lib/content-api';

const features = await getFeatures();

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": Astro.url.href,
  "url": Astro.url.href,
  "name": "Platform Features",
  "description": "Everything you need to run a professional coaching business — scheduling, client management, video sessions, and payments in one platform.",
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": features.length,
    "itemListElement": features.map((feature, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "SoftwareApplication",
        "name": feature.title,
        "description": feature.description,
        "url": `${Astro.url.href}#${feature.id || index}`
      }
    }))
  }
};
---

<Layout title="Platform Features" schema={schema}>
  <!-- Hero section -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 w-full overflow-hidden bg-gradient-to-b from-[#030014]/40 to-transparent">
    <div class="absolute inset-0 bg-radial-at-t from-indigo-500/10 via-transparent to-transparent pointer-events-none" />
    
    <div class="relative z-10 flex flex-col items-center justify-center px-6 text-center max-w-4xl mx-auto">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-indigo-400/20 bg-indigo-900/20 px-4 py-1.5 text-sm font-bold text-indigo-400">
        Platform Capabilities
      </div>
      <h1 class="mb-6 font-heading text-5xl font-black tracking-tighter sm:text-6xl md:text-7xl text-white drop-shadow-lg pb-2">
        Powerful <span class="bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent inline-block pb-1">Features</span>
      </h1>
      <p class="max-w-2xl text-lg text-slate-400 sm:text-xl font-medium leading-relaxed">
        Everything you need to run a professional coaching business — scheduling, client management, video sessions, and payments in one platform.
      </p>
    </div>
  </section>

  <!-- Dynamic Bento Grid (Migrated from Homepage) -->
  <ResearchGrid client:load areas={features} />

  <!-- Integrations Graph (Migrated from Homepage) -->
  <Integrations client:load />

  <!-- CTA Section -->
  <section class="border-t border-white/5 bg-[#030014] py-24 relative overflow-hidden">
    <div class="absolute bottom-0 right-1/4 h-80 w-80 rounded-full bg-indigo-500/5 blur-3xl pointer-events-none" />
    
    <div class="container mx-auto max-w-4xl px-6 text-center relative z-10 space-y-8">
      <h2 class="font-heading text-4xl font-black tracking-tighter sm:text-5xl text-white">
        Ready to Streamline Your Practice?
      </h2>
      <p class="text-xl text-slate-400 font-medium max-w-2xl mx-auto leading-relaxed">
        Join thousands of coaches who've replaced their patchwork of tools with one powerful platform.
      </p>
      <div class="flex flex-col justify-center gap-4 sm:flex-row pt-4">
        <a 
          href="https://app.nexushq.tech" 
          class="inline-flex items-center justify-center rounded-full bg-indigo-600 px-8 py-4 text-base font-bold text-white shadow-[0_0_20px_rgba(79,70,229,0.3)] transition-all duration-300 hover:scale-105 hover:bg-indigo-500"
        >
          Start Free Trial
        </a>
        <a 
          href="/pricing" 
          class="inline-flex items-center justify-center rounded-full border border-white/10 bg-slate-900/50 px-8 py-4 text-base font-bold text-white transition-all duration-300 hover:scale-105 hover:bg-white/5"
        >
          View Pricing
        </a>
      </div>
    </div>
  </section>
</Layout>
