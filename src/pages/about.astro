---
import Layout from '../layouts/Layout.astro';
import { Target, Lightbulb, Scale } from 'lucide-react';
import { getSiteSettings } from '../lib/content-api';
import type { AboutContent, SiteData } from '../types';

const defaultAboutContent: AboutContent = {
  mission: 'Our mission is to empower coaches, tutors, and mentors with the tools they need to build thriving businesses.',
  preamble: 'NexusHQ was born from a simple observation: coaches spend more time on admin than on coaching.\\n\\nWe built a platform that handles scheduling, payments, client management, and video sessions — so you can focus on what you do best.',
  vision: 'A world where every great coach has the tools to scale their impact, without the overhead.'
};

const defaultSiteData: SiteData = {
  name: 'NexusHQ Technologies',
  abbreviation: 'NexusHQ',
  tagline: 'The Coaching Platform for Modern Mentors',
  contact: {
    email: 'hello@nexushq.tech',
    phone: '+1-800-NEXUS-HQ',
    address: 'Remote-first, Global'
  }
};

const aboutContent = (await getSiteSettings<AboutContent>('about_content')) || defaultAboutContent;
const siteData = (await getSiteSettings<SiteData>('site_data')) || defaultSiteData;

const orgSchema = (siteData && siteData.contact) ? {
  "@type": "Organization",
  "@id": `${Astro.url.origin}/#organization`,
  "name": siteData.name,
  "alternateName": siteData.abbreviation,
  "slogan": siteData.tagline,
  "url": Astro.url.origin,
  "logo": new URL('/favicon.png', Astro.url).href,
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": siteData.contact.phone,
    "email": siteData.contact.email,
    "contactType": "customer service"
  }
} : null;

const aboutPageSchema = {
  "@type": "AboutPage",
  "@id": Astro.url.href,
  "url": Astro.url.href,
  "name": "About NexusHQ",
  "description": aboutContent.mission,
  "about": orgSchema ? { "@id": `${Astro.url.origin}/#organization` } : undefined
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    aboutPageSchema,
    ...(orgSchema ? [orgSchema] : [])
  ]
};

const values = [
  { title: 'Simplicity', icon: Scale, desc: 'We believe powerful software should be effortless to use. No training manuals required.' },
  { title: 'Coach-First', icon: Lightbulb, desc: 'Every feature we build starts with one question: does this help coaches serve their clients better?' },
  { title: 'Reliability', icon: Target, desc: 'Your clients depend on you, and you depend on us. We take that seriously with 99.9% uptime.' },
];
---

<Layout title="About NexusHQ" schema={schema}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden border-b border-border/50 pt-32 pb-24 md:pt-40 md:pb-32 bg-[#030014]">
    <!-- Glowing background accents -->
    <div class="absolute -top-40 -right-20 h-[500px] w-[500px] rounded-full bg-indigo-500/10 blur-[120px] pointer-events-none"></div>
    <div class="absolute top-20 -left-20 h-[400px] w-[400px] rounded-full bg-violet-600/10 blur-[100px] pointer-events-none"></div>
    
    <div class="container mx-auto max-w-7xl px-6 relative z-10">
      <div class="max-w-4xl animate-fadeInUp">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
          About Us
        </div>
        <h1 class="mb-8 font-heading text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl pb-2">
          Built by coaches, <span class="bg-gradient-to-r from-primary to-violet-500 bg-clip-text text-transparent inline-block pb-1">for coaches</span>
        </h1>
        <p class="text-xl leading-relaxed text-slate-300 sm:text-2xl font-light">
          {aboutContent.mission}
        </p>
      </div>
    </div>
  </section>

  <!-- Values Grid -->
  <section class="py-24 relative">
    <div class="absolute top-1/3 left-10 h-96 w-96 rounded-full bg-indigo-500/5 blur-3xl pointer-events-none" />
    <div class="container mx-auto max-w-7xl px-6">
      <div class="grid gap-8 md:grid-cols-3">
        {values.map((val) => {
          const Icon = val.icon;

          return (
            <div class="group relative overflow-hidden rounded-2xl border border-white/5 bg-slate-950/45 p-8 transition-all duration-300 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/5 glow-border">
              <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 text-primary transition-all duration-300 group-hover:bg-primary group-hover:text-white">
                <Icon className="h-7 w-7" aria-hidden="true" />
              </div>
              <h3 class="mb-4 font-heading text-2xl font-bold text-white group-hover:text-primary transition-colors">{val.title}</h3>
              <p class="text-slate-400 leading-relaxed text-sm md:text-base font-medium">{val.desc}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="border-y border-border/50 bg-[#030014]/40 py-24">
    <div class="container mx-auto max-w-7xl px-6">
      <div class="max-w-3xl mx-auto space-y-6 animate-fadeInUp">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">Our Story</p>
        <h2 class="font-heading text-3xl font-extrabold tracking-tight sm:text-4xl text-white">Why We Built NexusHQ</h2>
        
        <div class="prose prose-lg dark:prose-invert text-slate-400 space-y-6 text-base md:text-lg leading-relaxed font-medium">
          {aboutContent.preamble
            .replace(/\\\\n\\\\n/g, '\n\n')
            .replace(/\\\\n/g, ' ')
            .split('\n\n')
            .filter((p) => p.trim())
            .map((paragraph) => (
              <p>{paragraph.trim()}</p>
            ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Vision Section -->
  <section class="py-24 relative overflow-hidden bg-gradient-to-t from-[#030014]/60 to-transparent">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-80 w-80 rounded-full bg-primary/5 blur-3xl pointer-events-none" />
    
    <div class="container mx-auto max-w-7xl px-6 text-center relative z-10 animate-fadeInUp">
      <p class="mb-6 text-sm font-semibold uppercase tracking-widest text-primary">Our Vision</p>
      <blockquote class="mx-auto max-w-4xl font-heading text-2xl font-semibold italic leading-relaxed text-white md:text-3xl lg:text-4xl">
        &ldquo;{aboutContent.vision}&rdquo;
      </blockquote>
    </div>
  </section>
</Layout>
