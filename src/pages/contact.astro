---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/contact/ContactForm';
import { Mail, Phone, MapPin, Clock } from 'lucide-react';
import { getSiteSettings } from '../lib/content-api';
import type { SiteData } from '../types';

const defaultSiteData: SiteData = {
  name: 'NexusHQ Technologies',
  abbreviation: 'NexusHQ',
  tagline: 'The Coaching Platform for Modern Mentors',
  contact: {
    email: 'hello@nexushq.tech',
    phone: '+1-800-NEXUS-HQ',
    address: 'Remote-first, Global'
  }
};

const siteData = (await getSiteSettings<SiteData>('site_data')) || defaultSiteData;

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": Astro.url.href,
  "url": Astro.url.href,
  "name": "Contact Us",
  "description": "Have questions about NexusHQ? Want to discuss enterprise plans or partnerships? We're here to help.",
  "mainEntity": {
    "@type": "Organization",
    "@id": `${Astro.url.origin}/#organization`,
    "name": siteData.name,
    "alternateName": siteData.abbreviation,
    "url": Astro.url.origin,
    "contactPoint": [
      {
        "@type": "ContactPoint",
        "telephone": siteData.contact.phone,
        "email": siteData.contact.email,
        "contactType": "customer service",
        "hoursAvailable": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "09:00",
            "closes": "18:00"
          }
        ]
      }
    ]
  }
};
---

<Layout title="Contact Us" schema={schema}>
  <!-- Hero Header -->
  <section class="border-b border-border/50 py-20 sm:py-24 lg:py-28 bg-gradient-to-b from-[#030014]/60 to-transparent">
    <div class="container mx-auto max-w-7xl px-6">
      <div class="max-w-3xl animate-fadeInUp">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary">Get In Touch</p>
        <h1 class="mb-6 font-heading text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
          Let's Start a <span class="bg-gradient-to-r from-primary to-violet-500 bg-clip-text text-transparent">Conversation</span>
        </h1>
        <p class="text-xl leading-relaxed text-slate-350 font-light">
          Have questions about NexusHQ? Want to discuss enterprise plans, APIs, or custom integrations? We're here to help.
        </p>
      </div>
    </div>
  </section>

  <!-- Split Contact Section -->
  <section class="py-20 relative">
    <div class="absolute top-1/4 right-0 h-96 w-96 rounded-full bg-primary/5 blur-3xl pointer-events-none" />
    <div class="absolute bottom-10 left-10 h-80 w-80 rounded-full bg-violet-500/5 blur-3xl pointer-events-none" />
    
    <div class="container mx-auto max-w-7xl px-6 relative z-10">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-start">
        
        <!-- Info Column -->
        <div class="space-y-12 animate-fadeInUp">
          <div>
            <h2 class="text-2xl font-bold tracking-tight text-white mb-6 font-heading">
              Contact Information
            </h2>
            <div class="grid gap-6">
              
              <!-- Address -->
              <div class="group flex items-start gap-4 rounded-xl border border-white/5 bg-slate-950/40 p-5 hover:border-primary/35 transition-colors glow-border">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-white">
                  <MapPin class="h-5 w-5" />
                </div>
                <div class="space-y-1">
                  <p class="font-semibold text-white text-sm uppercase tracking-wider">Headquarters</p>
                  <p class="text-slate-400 text-base leading-relaxed">{siteData.contact.address}</p>
                </div>
              </div>

              <!-- Email -->
              <div class="group flex items-start gap-4 rounded-xl border border-white/5 bg-slate-950/40 p-5 hover:border-primary/35 transition-colors glow-border">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-white">
                  <Mail class="h-5 w-5" />
                </div>
                <div class="space-y-1">
                  <p class="font-semibold text-white text-sm uppercase tracking-wider">Email</p>
                  <a href={`mailto:${siteData.contact.email}`} class="text-slate-400 text-base hover:text-primary transition-colors block">
                    {siteData.contact.email}
                  </a>
                </div>
              </div>

              <!-- Phone -->
              <div class="group flex items-start gap-4 rounded-xl border border-white/5 bg-slate-950/40 p-5 hover:border-primary/35 transition-colors glow-border">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-white">
                  <Phone class="h-5 w-5" />
                </div>
                <div class="space-y-1">
                  <p class="font-semibold text-white text-sm uppercase tracking-wider">Phone</p>
                  <p class="text-slate-400 text-base">{siteData.contact.phone}</p>
                </div>
              </div>

            </div>
          </div>

          <!-- Support Hours -->
          <div class="rounded-2xl border border-white/5 bg-slate-950/30 p-6 space-y-4">
            <h3 class="text-lg font-bold text-white flex items-center gap-2">
              <Clock class="h-5 w-5 text-primary" />
              Support Hours
            </h3>
            <div class="grid grid-cols-2 gap-4 text-base text-slate-400">
              <div>Monday &ndash; Friday</div>
              <div class="text-white font-semibold">9:00 AM &ndash; 6:00 PM EST</div>
              <div>Saturday &ndash; Sunday</div>
              <div class="text-indigo-400 font-semibold">Closed</div>
            </div>
          </div>
        </div>

        <!-- Form Column -->
        <ContactForm client:load />

      </div>
    </div>
  </section>
</Layout>
