---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import ResearchGrid from '../components/home/ResearchGrid';
import GoalsSection from '../components/home/GoalsSection.astro';
import JoinTeamSection from '../components/home/JoinTeamSection';


import { getFeatures, getSiteSettings } from '../lib/content-api';
import type { SiteData } from '../types';

// Fetch data from backend (or fallback)
const areas = await getFeatures();
const siteData = await getSiteSettings<SiteData>('site_data');

const schema = (siteData && siteData.contact) ? {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "NexusHQ",
  "applicationCategory": "BusinessApplication",
  "description": siteData.tagline || "The all-in-one coaching platform for modern mentors.",
  "url": Astro.url.href,
  "logo": new URL('/favicon.png', Astro.url).href,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "description": "Free trial available"
  }
} : undefined;
---
<Layout schema={schema}>
  <!-- Static Hero Component (zero client JS) -->
  <Hero />
  
  <!-- Interactive Features Grid hydrated immediately for framer-motion -->
  <ResearchGrid client:load areas={areas} />
  
  <!-- Static Value Props Section (zero client JS) -->
  <GoalsSection />
  
  <!-- Interactive signup form hydrated immediately -->
  <JoinTeamSection client:load />

</Layout>
