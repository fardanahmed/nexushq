---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import ResearchGrid from '../components/home/ResearchGrid';
import GoalsSection from '../components/home/GoalsSection.astro';
import JoinTeamSection from '../components/home/JoinTeamSection';
import Interactive3DBackground from '../components/home/Interactive3DBackground';

import { getResearchAreas, getSiteSettings } from '../lib/content-api';
import type { SiteData } from '../types';

// Fetch data from Neon DB
const areas = await getResearchAreas();
const siteData = await getSiteSettings<SiteData>('site_data');

const schema = (siteData && siteData.contact) ? {
  "@context": "https://schema.org",
  "@type": "ResearchOrganization",
  "name": siteData.name,
  "alternateName": siteData.abbreviation,
  "slogan": siteData.tagline,
  "url": Astro.url.href,
  "logo": new URL('/favicon.png', Astro.url).href,
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": siteData.contact.phone,
    "email": siteData.contact.email,
    "contactType": "customer service"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": siteData.contact.address
  }
} : undefined;
---

<Layout schema={schema}>
  <!-- Global 3D Background -->
  <Interactive3DBackground client:load />

  <!-- Static Hero Component (zero client JS) -->
  <Hero />
  
  <!-- Interactive Research Grid hydrated immediately for framer-motion -->
  <ResearchGrid client:load areas={areas} />
  
  <!-- Static Goals Section (zero client JS) -->
  <GoalsSection />
  
  <!-- Interactive signup form hydrated immediately -->
  <JoinTeamSection client:load />

  <!-- Global Loading Screen overlay -->
  <div id="global-loader" class="fixed inset-0 z-[100] flex flex-col items-center justify-center bg-slate-950 transition-opacity duration-700">
    <!-- 3D Gyroscope Loader -->
    <div class="gyroscope mb-12">
      <div class="gyro-ring"></div>
      <div class="gyro-ring"></div>
      <div class="gyro-ring"></div>
      <div class="gyro-core"></div>
    </div>
    
    <!-- Text -->
    <h2 class="text-3xl font-bold tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-violet-400 animate-pulse">CARER</h2>
    <p class="text-slate-400 mt-2 tracking-widest text-sm uppercase">Initializing WebGL</p>
  </div>
  
  <style>
    .gyroscope {
      width: 140px;
      height: 140px;
      position: relative;
      perspective: 1000px;
      transform-style: preserve-3d;
    }
    .gyro-ring {
      position: absolute;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: 3px solid transparent;
      box-shadow: inset 0 0 15px rgba(255,255,255,0.05);
    }
    .gyro-ring:nth-child(1) {
      border-top-color: #06b6d4; /* Cyan */
      border-bottom-color: #06b6d4;
      animation: spin1 2s linear infinite;
    }
    .gyro-ring:nth-child(2) {
      border-right-color: #8b5cf6; /* Violet */
      border-left-color: #8b5cf6;
      animation: spin2 2.5s linear infinite;
    }
    .gyro-ring:nth-child(3) {
      border-top-color: #3b82f6; /* Blue */
      border-bottom-color: #3b82f6;
      animation: spin3 3s linear infinite;
    }
    .gyro-core {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 30px;
      height: 30px;
      margin: -15px 0 0 -15px;
      background: radial-gradient(circle, #06b6d4, #8b5cf6);
      border-radius: 50%;
      box-shadow: 0 0 30px #06b6d4, 0 0 60px #8b5cf6;
      animation: pulse-core 2s infinite alternate;
    }

    @keyframes spin1 { 
      0% { transform: rotateX(60deg) rotateY(0deg) rotateZ(0deg); } 
      100% { transform: rotateX(60deg) rotateY(0deg) rotateZ(360deg); } 
    }
    @keyframes spin2 { 
      0% { transform: rotateX(0deg) rotateY(60deg) rotateZ(0deg); } 
      100% { transform: rotateX(0deg) rotateY(60deg) rotateZ(360deg); } 
    }
    @keyframes spin3 { 
      0% { transform: rotateX(45deg) rotateY(45deg) rotateZ(0deg); } 
      100% { transform: rotateX(45deg) rotateY(45deg) rotateZ(360deg); } 
    }
    @keyframes pulse-core { 
      0% { transform: scale(0.8); opacity: 0.8; } 
      100% { transform: scale(1.2); opacity: 1; } 
    }
  </style>

  <script is:inline>
    if (sessionStorage.getItem('3d-scene-loaded') === 'true') {
      // Bypass the loading screen entirely for repeat visits
      document.write('<style>#global-loader { display: none !important; }</style>');
    } else {
      // Because we use 'scrollbar-gutter: stable' in html, we can safely lock body scrolling
      // without causing a horizontal layout shift.
      document.body.style.overflow = 'hidden';
    }
    
    // Listen for the React component to signal it's done
    window.addEventListener('3d-scene-ready', () => {
      const loader = document.getElementById('global-loader');
      if (loader) {
        loader.style.opacity = '0';
        setTimeout(() => {
          loader.remove();
          document.body.style.overflow = '';
        }, 700);
      }
    });
    
    // Failsafe: if the 3D scene crashes or takes too long, remove the loader after 5s
    setTimeout(() => {
      window.dispatchEvent(new Event('3d-scene-ready'));
    }, 5000);
  </script>
</Layout>
