---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import TrustBar from '../components/home/TrustBar.astro';
import TheOffer from '../components/home/TheOffer.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import Testimonials from '../components/home/Testimonials';
import JoinTeamSection from '../components/home/JoinTeamSection';

import { getSiteSettings } from '../lib/content-api';
import type { SiteData } from '../types';

// Fetch data from backend (or fallback)
const siteData = await getSiteSettings<SiteData>('site_data');

const schema = (siteData && siteData.contact) ? {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "NexusHQ",
  "applicationCategory": "BusinessApplication",
  "description": siteData.tagline || "The all-in-one coaching platform for modern mentors.",
  "url": Astro.url.href,
  "logo": new URL('/favicon.png', Astro.url).href,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "description": "Free trial available"
  }
} : undefined;
---
<Layout schema={schema}>
  <!-- Static Hero Component -->
  <Hero />
  
  <!-- Immediate Social Proof -->
  <TrustBar />

  <!-- The Irresistible VIP Beta Offer -->
  <TheOffer />

  <!-- Process Visualization -->
  <HowItWorks />

  <!-- Hard Social Proof -->
  <Testimonials />
  
  <!-- Final CTA / Signup Form -->
  <JoinTeamSection client:load />

</Layout>
