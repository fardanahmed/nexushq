---
import Layout from '../layouts/Layout.astro';
import { Card, CardHeader, CardTitle, CardContent } from '../components/ui/card';
import { Button } from '../components/ui/button';
import { Zap, Activity, Sprout, Cpu, Calculator, ArrowRight, type LucideIcon } from 'lucide-react';
import { getResearchAreas } from '../lib/content-api';
import { getImageUrl } from '../lib/images';

const researchAreas = await getResearchAreas();
const videoUrl = getImageUrl('Scene_a_scientific_1080p_202601202028.mp4');

const iconMap: Record<string, LucideIcon> = { Zap, Activity, Sprout, Cpu, Calculator };

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": Astro.url.href,
  "url": Astro.url.href,
  "name": "Research Frontiers",
  "description": "Exploring the intersections of foundational engineering, machine intelligence, and sustainable technologies to solve industrial and clinical needs.",
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": researchAreas.length,
    "itemListElement": researchAreas.map((area, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "ResearchProject",
        "name": area.title,
        "description": area.description,
        "url": `${Astro.url.href}#${area.id || index}`
      }
    }))
  }
};
---

<Layout title="Research Frontiers" schema={schema}>
  <!-- Video hero section (Highly Optimized) -->
  <section class="relative h-[65vh] min-h-[500px] w-full overflow-hidden bg-slate-950 text-white">
    <video autoPlay muted playsInline class="absolute inset-0 h-full w-full object-cover opacity-35" preload="auto">
      <source src={videoUrl} type="video/mp4" />
    </video>
    <!-- Modern gradient overlays -->
    <div class="absolute inset-0 bg-gradient-to-t from-background via-slate-950/60 to-transparent" />
    <div class="absolute inset-0 bg-radial-at-t from-primary/10 via-transparent to-transparent" />
    
    <div class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center max-w-4xl mx-auto">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
        Our Investigation
      </div>
      <h1 class="mb-6 font-heading text-5xl font-extrabold tracking-tight sm:text-6xl md:text-7xl">
        Research <span class="bg-gradient-to-r from-primary to-blue-400 bg-clip-text text-transparent">Frontiers</span>
      </h1>
      <p class="max-w-2xl text-lg text-slate-300 sm:text-xl font-light leading-relaxed">
        Exploring the intersections of foundational engineering, machine intelligence, and sustainable technologies to solve industrial and clinical needs.
      </p>
    </div>
  </section>

  <!-- Research Grid Section (Modernized UI with Glass Cards) -->
  <section class="py-24 relative">
    <div class="container mx-auto max-w-7xl px-6">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {researchAreas.map((area) => {
          const Icon = iconMap[area.icon] || Zap;
          return (
            <article class="flex flex-col h-full">
              <Card className="group flex flex-col flex-1 relative overflow-hidden border-border bg-card/45 backdrop-blur-md transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:border-primary/50 hover:bg-card">
                <!-- Animated hover accent border -->
                <div class="absolute left-0 top-0 h-full w-1.5 bg-primary scale-y-0 transition-transform duration-300 group-hover:scale-y-100" />
                
                <CardHeader className="flex-none pb-4">
                  <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary transition-all duration-300 group-hover:bg-primary group-hover:text-white">
                    <Icon className="h-6 w-6" />
                  </div>
                  <CardTitle className="text-2xl font-bold tracking-tight text-foreground transition-colors duration-200 group-hover:text-primary">
                    {area.title}
                  </CardTitle>
                </CardHeader>
                
                <CardContent className="flex-grow">
                  <p class="text-muted-foreground leading-relaxed text-base">
                    {area.description}
                  </p>
                </CardContent>
                
                <div class="p-6 pt-0 flex-none">
                  <Button variant="ghost" className="group pl-0 text-primary hover:text-primary/80 hover:bg-transparent transition-colors font-semibold">
                    <span>Explore Projects</span>
                    <ArrowRight class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" />
                  </Button>
                </div>
              </Card>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Collaboration CTA -->
  <section class="border-t border-border/50 bg-muted/20 py-24 relative overflow-hidden">
    <div class="absolute bottom-0 right-1/4 h-80 w-80 rounded-full bg-primary/5 blur-3xl pointer-events-none" />
    
    <div class="container mx-auto max-w-4xl px-6 text-center relative z-10 space-y-8">
      <h2 class="font-heading text-3xl font-extrabold tracking-tight sm:text-4xl text-foreground">
        Interested in Collaborating?
      </h2>
      <p class="text-xl text-muted-foreground max-w-2xl mx-auto leading-relaxed">
        We collaborate with leading research institutes, clinical partners, and technology enterprises globally to bring prototypes to scale.
      </p>
      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        <a 
          href="/contact" 
          class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-4 text-base font-bold text-white shadow-xl shadow-primary/10 transition-all duration-300 hover:scale-105 hover:bg-primary/95"
        >
          Contact Us
        </a>
        <a 
          href="/about" 
          class="inline-flex items-center justify-center rounded-full border border-border bg-card px-8 py-4 text-base font-bold text-foreground transition-all duration-300 hover:scale-105 hover:bg-accent"
        >
          Learn About Our Mission
        </a>
      </div>
    </div>
  </section>
</Layout>
