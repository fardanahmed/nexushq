---
import Layout from '../layouts/Layout.astro';
import { Card, CardContent } from '../components/ui/card';
import { GraduationCap, Briefcase, Mail, Cpu, ArrowRight } from 'lucide-react';
import type { TeamMember } from '../types';

const teamMembers: TeamMember[] = [
  {
    id: 1,
    name: 'Dr. Fardan Ahmed',
    role: 'Principal Investigator',
    department: 'Computer Science & Engineering',
    specialization: 'AI in Healthcare, Assistive Technologies, Deep Learning',
    education: 'Ph.D. in Computer Science',
    email: 'fardan@carer.edu.pk',
    display_order: 1
  },
  {
    id: 2,
    name: 'Dr. Sarah Qureshi',
    role: 'Senior Research Fellow',
    department: 'Robotics & Control Systems',
    specialization: 'Kinematics, Rehabilitation Exoskeletons, Haptic Feedback',
    education: 'Ph.D. in Mechanical Engineering',
    email: 'sarah@carer.edu.pk',
    display_order: 2
  },
  {
    id: 3,
    name: 'Engr. Bilal Khan',
    role: 'Lead Hardware Architect',
    department: 'Mechatronics Engineering',
    specialization: 'Embedded Systems, Sensors Integration, Rapid Prototyping',
    education: 'M.S. in Mechatronics',
    email: 'bilal@carer.edu.pk',
    display_order: 3
  },
  {
    id: 4,
    name: 'Dr. Zainab Fatima',
    role: 'Clinical Research Coordinator',
    department: 'Bioengineering & Rehabilitation',
    specialization: 'Neural Interfaces, Clinical Trials, Prosthetic Assessment',
    education: 'Ph.D. in Bioengineering',
    email: 'zainab@carer.edu.pk',
    display_order: 4
  }
];

const openPositions = [
  {
    title: 'Research Assistant — Deep Learning',
    department: 'Computer Science & Engineering',
    type: 'Full-time',
    description: 'Seeking a research assistant to work on machine vision and deep learning models for rehabilitation assessment.'
  },
  {
    title: 'Mechanical Design Engineer',
    department: 'Mechatronics Engineering',
    type: 'Full-time',
    description: 'Work on the mechanical layout and structural analysis of assistive exoskeletons and orthotic systems.'
  },
  {
    title: 'Postdoctoral Fellow — Brain-Computer Interfaces',
    department: 'Bioengineering',
    type: '2-Year Contract',
    description: 'Conduct research on neural signal decoding and haptic closed-loop feedback interfaces.'
  }
];

const personSchemas = teamMembers.map((member) => ({
  "@type": "Person",
  "name": member.name,
  "jobTitle": member.role,
  "worksFor": {
    "@type": "ResearchOrganization",
    "name": "Nasir Uddin Centre for Applied Research & Educational Resources",
    "alternateName": "CARER"
  },
  "email": member.email,
  "knowsAbout": member.specialization.split(',').map((s) => s.trim()),
  "alumniOf": {
    "@type": "EducationalOrganization",
    "name": member.education
  }
}));

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": Astro.url.href,
  "url": Astro.url.href,
  "name": "Our Research Team",
  "description": "An interdisciplinary team of engineers, clinical researchers, and computer scientists working together to bridge academic research with life-enhancing technologies.",
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": teamMembers.length,
    "itemListElement": personSchemas.map((person, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": person
    }))
  }
};
---

<Layout title="Our Research Team" schema={schema}>
  <!-- Hero Section -->
  <section class="border-b border-border/50 py-20 sm:py-24 lg:py-28 bg-gradient-to-b from-slate-950/20 to-transparent">
    <div class="container mx-auto max-w-7xl px-6">
      <div class="max-w-3xl">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary">The Minds</p>
        <h1 class="mb-6 font-heading text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
          Meet the <span class="bg-gradient-to-r from-primary to-blue-500 bg-clip-text text-transparent">Researchers</span>
        </h1>
        <p class="text-xl leading-relaxed text-muted-foreground font-light">
          An interdisciplinary team of engineers, clinical researchers, and computer scientists working together to bridge academic research with life-enhancing technologies.
        </p>
      </div>
    </div>
  </section>

  <!-- Team Grid -->
  <section class="py-20 relative">
    <div class="absolute top-1/3 left-0 h-96 w-96 rounded-full bg-primary/5 blur-3xl pointer-events-none" />
    
    <div class="container mx-auto max-w-7xl px-6 relative z-10">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-2 max-w-5xl mx-auto">
        {teamMembers.map((member) => (
          <Card className="group relative overflow-hidden border-border bg-card/45 backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-primary/50 hover:bg-card flex flex-col justify-between">
            <div class="absolute left-0 top-0 h-full w-1.5 bg-primary scale-y-0 transition-transform duration-300 group-hover:scale-y-100" />
            
            <CardContent class="p-6 md:p-8 space-y-6">
              
              <!-- Profile Header (Initials Badge + Name/Role) -->
              <div class="flex items-center gap-5">
                <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-primary to-blue-600 text-white font-heading font-bold text-2xl shadow-lg shadow-primary/20">
                  {member.name.split(' ').map(n => n[0]).join('')}
                </div>
                <div class="space-y-1">
                  <h3 class="text-2xl font-bold tracking-tight text-foreground transition-colors group-hover:text-primary">
                    {member.name}
                  </h3>
                  <p class="text-primary font-semibold text-sm tracking-wider uppercase">{member.role}</p>
                </div>
              </div>
              
              <!-- Details -->
              <div class="space-y-3.5 text-base md:text-lg border-t border-border/50 pt-4 text-muted-foreground">
                <p class="flex items-center gap-2.5">
                  <Briefcase class="h-5 w-5 text-primary shrink-0" />
                  <span>{member.department}</span>
                </p>
                <p class="flex items-center gap-2.5">
                  <GraduationCap class="h-5 w-5 text-primary shrink-0" />
                  <span>{member.education}</span>
                </p>
                <p class="flex items-start gap-2.5 leading-relaxed">
                  <Cpu class="h-5 w-5 text-primary mt-1 shrink-0" />
                  <span><strong>Focus:</strong> {member.specialization}</span>
                </p>
              </div>

              <!-- Contact Button -->
              <div class="pt-4 border-t border-border/50 flex justify-between items-center">
                <a 
                  href={`mailto:${member.email}`}
                  class="inline-flex items-center gap-2 text-sm font-semibold text-muted-foreground hover:text-primary transition-colors group/link"
                >
                  <Mail class="h-4.5 w-4.5 group-hover/link:scale-110 transition-transform" />
                  {member.email}
                </a>
              </div>

            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Positions -->
  <section class="border-t border-border/50 bg-muted/20 py-24 relative overflow-hidden">
    <div class="absolute bottom-0 right-1/4 h-80 w-80 rounded-full bg-primary/5 blur-3xl pointer-events-none" />
    
    <div class="container mx-auto max-w-5xl px-6 relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-16 space-y-4">
        <h2 class="font-heading text-3xl font-extrabold tracking-tight sm:text-4xl text-foreground">
          Join Our Research Desk
        </h2>
        <p class="text-lg text-muted-foreground">
          Explore open research positions, internships, and clinical assistant fellowships.
        </p>
      </div>

      <div class="grid gap-6 max-w-4xl mx-auto">
        {openPositions.map((job) => (
          <div class="group relative overflow-hidden rounded-2xl border border-border bg-card p-6 md:p-8 transition-all duration-300 hover:border-primary/50 hover:shadow-lg flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="space-y-2.5 max-w-2xl">
              <div class="flex flex-wrap items-center gap-2.5">
                <h3 class="text-xl font-bold text-foreground group-hover:text-primary transition-colors">
                  {job.title}
                </h3>
                <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">
                  {job.type}
                </span>
              </div>
              <p class="text-sm font-medium text-primary uppercase tracking-wider">{job.department}</p>
              <p class="text-muted-foreground leading-relaxed text-base">{job.description}</p>
            </div>
            
            <a 
              href={`/contact?subject=Application%20for%20${encodeURIComponent(job.title)}`}
              class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-bold text-white shadow-lg shadow-primary/10 transition-all duration-300 hover:scale-105 hover:bg-primary/95 shrink-0"
            >
              Apply Now
              <ArrowRight class="ml-2 h-4 w-4" />
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
